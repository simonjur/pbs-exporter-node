{
  "name": "pbs-exporter",
  "version": "0.0.0",
  "description": "Export Proxmox Backup Server metrics for Prometheus",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "main": "src/run.ts",
  "scripts": {
    "start": "node --env-file=.env src/run.ts",
    "dev": "node --env-file=.env --watch src/run.ts",
    "lint:ts": "tsc --noEmit",
    "lint:eslint": "eslint \"**/*.ts\" src/web/app.js",
    "lint:prettier": "prettier --check \"**/*.ts\"",
    "format": "prettier --write \"**/*.ts\"",
    "tests:unit": "vitest run",
    "tests:unit:coverage": "vitest run --coverage",
    "build:fe": "node scripts/build-fe.mjs",
    "build": "tsc"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "parse-duration": "^2.1.6",
    "prom-client": "^15.1.3",
    "undici": "^7.16.0",
    "vue": "^3.5.38",
    "vuetify": "^3.12.8",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
